# Self-hosted Medusa dashboard configuration.
# Copy to .env and fill in. Full guide: https://medusasec.com/docs/deployment

# ── Supabase (required) ──────────────────────────────────────────────
# Your own Supabase project (self-hosted stack or a Cloud project in your
# account). These values are in your Supabase project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL where this dashboard is reachable.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Must be the SAME value you passed to the backend kit's selfhost-setup.mjs —
# it signs the policies the edge functions hand to the extension, and the
# dashboard verifies the signature with it. setup auto-generates one if you
# don't pass it; copy that value here.
POLICY_SIGNING_SECRET=your-policy-signing-secret

# ── Image (optional) ─────────────────────────────────────────────────
# Which tag docker-compose.yml pulls from GHCR. Defaults to :latest;
# pin a version (e.g. v1.0.0) for reproducible deployments.
MEDUSA_IMAGE_TAG=latest

# ── License (recommended) ────────────────────────────────────────────
# The signed key that sets this deployment's tier. Without it the dashboard
# runs at the free tier (3 endpoints, 30-day retention). Issued by Medusa;
# verified offline. Leave blank for free tier.
MEDUSA_LICENSE_KEY=

# ── Email (alerts, auth) ─────────────────────────────────────────────
# Outbound email uses SMTP if set (point it at the SAME SMTP server you
# configure in Supabase Auth). Otherwise it falls back to the Resend API.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@your-company.com
# Fallback transport (used only if SMTP_HOST is empty):
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@your-company.com

# ── Optional ─────────────────────────────────────────────────────────
# Only needed if this deployment also handles its own billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
